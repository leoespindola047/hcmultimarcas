<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Configurações - HC Multimarcas</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="style.css">
</head>

<body>

<nav class="navbar navbar-expand-lg navbar-dark">
  <div class="container">
    <a class="navbar-brand" href="index.html">HC <span>Multimarcas</span></a>
    <button class="navbar-toggler" data-bs-toggle="collapse" data-bs-target="#menu">
      <span class="navbar-toggler-icon"></span>
    </button>
    <div class="collapse navbar-collapse" id="menu">
      <ul class="navbar-nav ms-auto">
        <li class="nav-item"><a class="nav-link" href="index.html">Início</a></li>
        <li class="nav-item"><a class="nav-link" href="produtos.html">Produtos</a></li>
        <li class="nav-item"><a class="nav-link" href="sobre.html">Sobre</a></li>
        <li class="nav-item"><a class="nav-link active" href="contato.html">Contato</a></li>
      </ul>
    </div>
  </div>
</nav>

<section class="section-header">
  <style>.section-header::before { content: 'LOJA'; }</style>
  <h1>Configurações</h1>
  <p>Gestão de informações gerais</p>
</section>

<main class="container py-5">
    <div class="row justify-content-center">
        <div class="col-lg-10">
            <div class="contato-card">
                <p style="font-size:.72rem;font-weight:600;letter-spacing:2px;text-transform:uppercase;color:var(--destaque);margin-bottom:4px;">Painel de Controlo</p>
                <h2 style="font-family:'Bebas Neue',sans-serif;font-size:2rem;letter-spacing:3px;margin-bottom:1.5rem;">Informações da loja</h2>

                <form action="#" method="post" class="form-hc row g-3">
                    <div class="col-md-6">
                        <label for="Endereco">Endereço</label>
                        <input type="text" id="Endereco" name="Endereco" class="form-control" placeholder="Ex: Rua, Cidade - SC">
                    </div>

                    <div class="col-md-6">
                        <label for="Foto">URL da Foto/Logótipo</label>
                        <input type="text" id="Foto" name="Foto" class="form-control" placeholder="caminho/da/foto.jpg">
                    </div>

                    <div class="col-md-6">
                        <label for="Numero">Telefone / WhatsApp</label>
                        <input type="text" id="Numero" name="Numero" class="form-control" placeholder="(48) 99999-9999">
                    </div>

                    <div class="col-md-6">
                        <label for="Instagram">Instagram</label>
                        <input type="text" id="Instagram" name="Instagram" class="form-control" placeholder="@sualoja">
                    </div>

                    <div class="col-12 text-end mt-4">
                        <button type="submit" class="btn-hc-dark px-5">
                            Salvar Alterações
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</main>

<footer>
  <p><strong>HC Multimarcas</strong> — Tijucas / SC</p>
  <p>© 2026 Todos os direitos reservados</p>
</footer>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
